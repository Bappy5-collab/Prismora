# ─────────────────────────────────────────────────────────────
# Prismora — environment variables
# Copy this file to `.env.local` and fill in real values.
# ─────────────────────────────────────────────────────────────

# Supabase project URL and anon (public) key — safe to expose to the browser.
# Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service-role key — SERVER ONLY. Never expose to the browser.
# Used by privileged server routes (e.g. accepting invites).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI API key — SERVER ONLY. Used by /lib/ai.ts via the /api/ai route.
OPENAI_API_KEY=sk-your-openai-key

# Optional: override the OpenAI model (defaults to gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# Public base URL of the app (used for auth redirects + email links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Transactional email (SMTP / Nodemailer) — SERVER ONLY.
# Powers: team invites, task-assignment emails, and the welcome email.
# If these are left blank, email sending is skipped (the app still works).
#
# Gmail example: host=smtp.gmail.com, port=587, user=you@gmail.com,
#   pass=<16-char App Password> (create at https://myaccount.google.com/apppasswords).
# ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password-or-app-password
# Set to "true" only if using port 465 (implicit TLS). Port 587 uses STARTTLS.
SMTP_SECURE=false
# Friendly From header shown to recipients.
EMAIL_FROM=Prismora <no-reply@yourdomain.com>
