# ─────────────────────────────────────────────────────────────
# Prismora — environment variables
# Copy this file to `.env.local` and fill in real values.
# ─────────────────────────────────────────────────────────────

# Supabase project URL and anon (public) key — safe to expose to the browser.
# Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service-role key — SERVER ONLY. Never expose to the browser.
# Used by privileged server routes (e.g. accepting invites).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI API key — SERVER ONLY. Used by /lib/ai.ts via the /api/ai route.
OPENAI_API_KEY=sk-your-openai-key

# Optional: override the OpenAI model (defaults to gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# Public base URL of the app (used for auth redirects).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
